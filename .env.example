# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL — use the POOLED connection URL for Vercel serverless
# (find it in your Neon dashboard under "Connection string" → enable "Connection pooling")
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Set to your production domain after deploying to Vercel
NEXTAUTH_URL="https://your-app.vercel.app"

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Add authorized redirect URI: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Admin Credentials ─────────────────────────────────────────────────────────
# Used for the admin panel login (not Google OAuth)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD=""
ADMIN_EMAIL="admin@quizlet.internal"

# ── UPI Payment ───────────────────────────────────────────────────────────────
# Merchant UPI details shown to users on the payment screen (not secret)
UPI_ID=""
UPI_NAME="BittsQuiz"
NEXT_PUBLIC_UPI_ID=""
NEXT_PUBLIC_UPI_NAME="BittsQuiz"

# ── Background Music ──────────────────────────────────────────────────────────
# Publicly accessible MP3 URL — streamed directly by the browser
NEXT_PUBLIC_MUSIC_URL="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"

# ── Email / SMTP ───────────────────────────────────────────────────────────────
# Used for: feedback submissions → admin, new user registration alerts
# Gmail example: use App Password (not your regular password)
# Generate at: Google Account → Security → App Passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
# Where admin notification emails are sent (defaults to SMTP_USER if not set)
ADMIN_NOTIFY_EMAIL="your-gmail@gmail.com"

# ── Pusher (DinoRex real-time multiplayer) ────────────────────────────────────
# Create a free app at: https://pusher.com → Channels → Create app
# Recommended cluster for India: ap2 (Singapore)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap2"
# Public keys (safe to expose — used by the browser client)
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"

# ── Web Push / VAPID (browser push notifications) ─────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_EMAIL="mailto:your@email.com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
