generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  coins            Int           @default(0)
  totalCoinsEarned Int           @default(0)
  totalCorrect     Int           @default(0)
  totalAnswered    Int           @default(0)
  isAdmin          Boolean       @default(false)
  isLocked         Boolean       @default(false)
  isPro            Boolean       @default(false)
  proExpiresAt     DateTime?
  dailyCoinsEarned Int           @default(0)
  dailyCoinsReset  DateTime      @default(now())
  lastSeenAt           DateTime?
  isMax                Boolean       @default(false)
  maxExpiresAt         DateTime?
  schoolAccessOverride Boolean       @default(false)
  currentStreak        Int           @default(0)
  longestStreak        Int           @default(0)
  lastStreakDate       DateTime?
  streakFreezes        Int           @default(0)
  createdAt            DateTime      @default(now())
  accounts             Account[]
  sessions             Session[]
  quizAttempts         QuizAttempt[]
  ownedQuizlets        UserQuizlet[]
  quizzesCreated       Quiz[]            @relation("QuizAuthor")
  paymentRequests      PaymentRequest[]
  feedbacks            Feedback[]
  correctAnswers       CorrectAnswer[]
  notifications        Notification[]
  pushSubscriptions    PushSubscription[]
  milestones           UserMilestone[]
  followers            UserFollow[]  @relation("UserFollowing")
  following            UserFollow[]  @relation("UserFollowers")

  @@index([totalCoinsEarned])
  @@index([lastSeenAt])
  @@index([createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Quiz {
  id          String        @id @default(cuid())
  title       String
  description String?
  category    String
  difficulty  Int
  isOfficial  Boolean       @default(false)
  isNew       Boolean       @default(false)
  authorId    String
  author      User          @relation("QuizAuthor", fields: [authorId], references: [id])
  questions   Question[]
  attempts    QuizAttempt[]
  createdAt   DateTime      @default(now())

  @@index([category])
  @@index([authorId])
  @@index([isOfficial])
}

model Question {
  id           String  @id @default(cuid())
  quizId       String
  quiz         Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text         String
  options      Json
  correctIndex Int
  points       Int     @default(1)
  order        Int     @default(0)
  explanation  String? @db.Text
  readMoreUrl  String?
  imageUrl     String?

  @@index([quizId])
}

model QuizAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  score       Int
  total       Int
  coinsEarned Int
  completedAt DateTime @default(now())

  @@index([userId])
  @@index([quizId])
  @@index([completedAt])
}

model Quizlet {
  id          String        @id @default(cuid())
  name        String        @unique
  rarity      String
  pack        String
  icon        String
  colorFrom   String
  colorTo     String
  description String
  isHidden    Boolean       @default(false)
  sellValue   Int           @default(10)
  owners      UserQuizlet[]
}

model UserQuizlet {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  quizletId  String
  quizlet    Quizlet  @relation(fields: [quizletId], references: [id])
  obtainedAt DateTime @default(now())

  @@unique([userId, quizletId])
  @@index([userId])
}

model PaymentRequest {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "coins" | "pro"
  coins     Int?     // only set when type="coins"
  amountInr Int      // amount in INR (coins amount or 500 for pro)
  utrNumber String   // user-submitted UTR/transaction reference
  status    String   @default("pending") // "pending" | "approved" | "rejected"
  adminNote String?  // optional note from admin on rejection
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("General")
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model CorrectAnswer {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  questionId String
  createdAt  DateTime @default(now())

  @@unique([userId, questionId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "overtaken" | "top3_join" | "feedback_reply"
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Pack {
  id           String  @id @default(cuid())
  name         String
  description  String
  cost         Int
  slug         String  @unique
  icon         String
  colorFrom    String
  colorTo      String
  isFestival   Boolean @default(false)
  festivalDate String?
  isActive     Boolean @default(true)
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserMilestone {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  threshold Int      // 1000, 2000, ..., 50000
  earnedAt  DateTime @default(now())

  @@unique([userId, threshold])
  @@index([userId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User @relation("UserFollowers", fields: [followerId],  references: [id], onDelete: Cascade)
  following   User @relation("UserFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model DinoRexRoom {
  id             String    @id @default(cuid())
  code           String    @unique
  hostId         String
  status         String    @default("waiting") // waiting | playing | ended
  players        Json      // DinoRexPlayer[]
  questions      Json      @default("[]") // QuestionData[]
  currentQ       Int       @default(0)
  currentAnswers Json      @default("{}") // { [userId]: number }
  roundStartedAt DateTime?
  winner         String?   // userId of winner
  createdAt      DateTime  @default(now())

  @@index([code])
  @@index([status])
  @@index([createdAt])
}
